{
  "name": "lucas-kjaero-website",
  "type": "module",
  "version": "2.0.0",
  "private": true,
  "author": "Lucas Kjaero-Zhang <lucas@lucaskjaerozhang.com>",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "build:static": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "cy:run": "cypress run --browser electron",
    "lint": "npm run lint:styles && npm run lint:scripts",
    "lint:scripts": "eslint .",
    "lint:styles": "stylelint \"src/**/*.css\"",
    "lint:styles-fix": "stylelint \"src/**/*.css\" --fix",
    "test": "npm run build:static && start-server-and-test \"npm run preview -- --host 127.0.0.1 --port 4321\" http://127.0.0.1:4321 \"npm run cy:run\"",
    "prettier": "prettier --write **/*.{ts,tsx,css,astro,md,mdx} --ignore-path .gitignore"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/markdown-remark": "7.1.1",
    "@astrojs/mdx": "5.0.4",
    "@astrojs/react": "5.0.4",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@expressive-code/plugin-collapsible-sections": "^0.41.7",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@iconify-json/lucide": "^1.2.105",
    "@shikijs/rehype": "^4.0.2",
    "@tailwindcss/vite": "4.2.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "astro": "6.2.0",
    "astro-icon": "^1.1.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html-entities": "^2.6.0",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.3.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "rehype-expressive-code": "^0.41.7",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "remark-emoji": "^5.0.1",
    "remark-math": "^6.0.0",
    "sanitize-html": "^2.17.3",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "4.2.4",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/sanitize-html": "^2.16.1",
    "cypress": "^15.14.2",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "prettier": "^3.5.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-astro-organize-imports": "^0.4.11",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "start-server-and-test": "^3.0.2",
    "stylelint": "^17.9.1",
    "stylelint-config-standard": "^40.0.0",
    "typescript-eslint": "^8.59.1"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "plugins": [
      "prettier-plugin-astro",
      "prettier-plugin-tailwindcss",
      "prettier-plugin-astro-organize-imports"
    ],
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      }
    ]
  }
}
