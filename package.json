{
  "name": "lucas-kjaero-website",
  "type": "module",
  "version": "2.0.0",
  "private": true,
  "author": "Lucas Kjaero-Zhang <lucas@lucaskjaerozhang.com>",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "build:static": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "cy:run": "cypress run --browser electron",
    "test": "npm run build:static && start-server-and-test \"npm run preview -- --host 127.0.0.1 --port 4321\" http://127.0.0.1:4321 \"npm run cy:run\"",
    "prettier": "prettier --write **/*.{ts,tsx,css,astro,md,mdx} --ignore-path .gitignore"
  },
  "dependencies": {
    "@astrojs/check": "0.9.7",
    "@astrojs/markdown-remark": "7.0.0",
    "@astrojs/mdx": "5.0.0",
    "@astrojs/react": "5.0.0",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.1",
    "@expressive-code/plugin-collapsible-sections": "^0.40.2",
    "@expressive-code/plugin-line-numbers": "^0.40.2",
    "@iconify-json/lucide": "^1.2.26",
    "@shikijs/rehype": "^3.4.0",
    "@tailwindcss/vite": "4.1.7",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "astro": "6.1.6",
    "astro-icon": "^1.1.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "radix-ui": "^1.3.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "rehype-expressive-code": "^0.40.2",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "remark-emoji": "^5.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "4.1.7",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "cypress": "^15.14.1",
    "prettier": "^3.5.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-astro-organize-imports": "^0.4.11",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "start-server-and-test": "^3.0.2"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "plugins": [
      "prettier-plugin-astro",
      "prettier-plugin-tailwindcss",
      "prettier-plugin-astro-organize-imports"
    ],
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      }
    ]
  }
}
